{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "capability_definition",
  "description": "Phase-1 P0 schema seed for capability_definition.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "capability_id": {
      "$ref": "./capability_id.schema.json"
    },
    "capability_kind": {
      "$ref": "../enums/capability_kind.schema.json"
    },
    "owner_module": {
      "type": "string",
      "minLength": 1
    },
    "contract_status": {
      "type": "string",
      "enum": [
        "active",
        "deprecated"
      ]
    },
    "summary": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "capability_id",
    "capability_kind",
    "owner_module",
    "contract_status"
  ]
}
